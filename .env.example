# Teacher Copilot — environment configuration.
# Copy to `.env` and fill in what you have. The app boots even if providers are
# missing; each provider is only required when its code path is exercised.

# --- Runtime ---
ENV=dev                         # dev | prod

# --- LLM providers (all optional at boot) ---
GROQ_API_KEY=                   # Groq free tier (fast text inference)
GEMINI_API_KEY=                 # Google AI Studio Gemini free tier (multimodal)
OLLAMA_URL=http://localhost:11434   # local last-resort fallback

# --- Model tiers (per provider, per workload; override to re-tier without code changes) ---
GROQ_FAST_MODEL=openai/gpt-oss-20b       # cheap/short calls (intent classification)
GROQ_SMART_MODEL=openai/gpt-oss-120b     # reasoning-heavy text
GEMINI_BULK_MODEL=gemini-3.1-flash-lite  # high-volume RAG / lesson-plan synthesis
GEMINI_SMART_MODEL=gemini-3.5-flash      # multimodal grading path

# --- Vector store ---
# Embedded (default) runs in-process with no server/Docker. Server mode is optional
# for deployment and uses QDRANT_URL.
QDRANT_MODE=embedded                 # embedded | server
QDRANT_PATH=./qdrant_data            # embedded-mode on-disk storage
QDRANT_URL=http://localhost:6333     # server mode only (future)

# --- Profile store ---
PROFILE_STORE_PATH=./data/profiles   # one JSON file per teacher

# --- Observability (optional; Phase 7) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
