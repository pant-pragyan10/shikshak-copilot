# Teacher Copilot — environment configuration.
# Copy to `.env` and fill in what you have. The app boots even if providers are
# missing; each provider is only required when its code path is exercised.

# --- Runtime ---
ENV=dev                         # dev | prod

# --- LLM providers (all optional at boot) ---
GROQ_API_KEY=                   # Groq free tier (fast text inference)
GEMINI_API_KEY=                 # Google AI Studio Gemini free tier (multimodal)
OLLAMA_URL=http://localhost:11434   # local last-resort fallback

# --- Vector store ---
QDRANT_URL=http://localhost:6333

# --- Observability (optional; Phase 7) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
