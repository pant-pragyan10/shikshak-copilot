# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Env / secrets
.env
*.local

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
.DS_Store

# Local data (keep the folders via .gitkeep, ignore contents)
data/curriculum/*
data/career/*
data/profiles/
!data/**/.gitkeep
# ...but ship the tiny synthetic sample corpus so RAG works out-of-the-box.
!data/curriculum/sample_*

# Qdrant (embedded local storage + any docker volume)
qdrant_data/
qdrant_storage/
